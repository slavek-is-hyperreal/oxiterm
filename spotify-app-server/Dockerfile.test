FROM python:3.12-slim

WORKDIR /app

COPY spotify-app-server/requirements-test.txt .
RUN pip install --no-cache-dir -r requirements-test.txt

COPY spotify-app-server/app.py .
COPY spotify-app-server/test_app.py .
COPY examples/spotify/ ./examples/spotify/

CMD ["python", "-m", "pytest", "test_app.py", "-v"]
