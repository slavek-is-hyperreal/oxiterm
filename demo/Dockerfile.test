FROM python:3.12-slim

WORKDIR /app

COPY requirements-test.txt .
RUN pip install --no-cache-dir -r requirements-test.txt

COPY app.py .
COPY test_app.py .

# .env is injected at runtime via --env-file — never baked into the image.
# Run tests with:
#   docker build -f Dockerfile.test -t spotify-app-test .
#   docker run --rm --env-file .env -e OXITERM_APP_TOKEN=<token> spotify-app-test
CMD ["python", "-m", "pytest", "test_app.py", "-v"]
